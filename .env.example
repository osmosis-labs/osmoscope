# Osmosis LCD API (Public endpoint, no key required)
NEXT_PUBLIC_LCD_BASE_URL=https://lcd.osmosis.zone

# Numia Data API
# Get your API key from: https://www.numia.xyz/
# Required for fetching historical staking APR data
NUMIA_API_KEY=your_numia_api_key_here

# Optional: Custom Numia API URL (defaults to public endpoint)
# NUMIA_API_URL=https://public-osmosis-api.numia.xyz

# Vercel Postgres Database (Primary storage)
# These are automatically set when you connect Vercel Postgres
# For local development: Create database in Vercel dashboard, then run `vercel env pull .env.local`
POSTGRES_URL="postgres://..."
POSTGRES_PRISMA_URL="postgres://..."
POSTGRES_URL_NON_POOLING="postgres://..."
POSTGRES_USER="default"
POSTGRES_HOST="..."
POSTGRES_PASSWORD="..."
POSTGRES_DATABASE="verceldb"

# Prisma 7 CLI datasource. prisma.config.ts reads DATABASE_URL for
# `db:generate` / `db:migrate`. Set it to the same value as POSTGRES_PRISMA_URL
# (Vercel does NOT set DATABASE_URL automatically). Required in the Vercel
# project env or the build's prisma generate will fail.
DATABASE_URL="postgres://..."

# Daily snapshot cron (Vercel Cron -> /api/cron/snapshot). The route rejects any
# request whose bearer token does not match this secret, so set it in the Vercel
# project env. Vercel automatically sends it as `Authorization: Bearer <secret>`
# on scheduled invocations. Generate a random value (e.g. `openssl rand -hex 32`).
CRON_SECRET=your_random_cron_secret_here
