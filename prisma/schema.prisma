// Prisma schema for Osmometer historical data
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs moved to prisma.config.ts (datasource.url) as required by
  // Prisma 7; url/directUrl are no longer permitted in the schema file.
}

model HistoricalRecord {
  id        BigInt   @id @default(autoincrement())
  timestamp DateTime @unique @db.Timestamptz(6)

  // Chain "day" epoch this snapshot was taken for. Set by the live snapshot cron;
  // null on archive-backfilled rows. The epoch-aware cron gates on this advancing,
  // so it MUST round-trip through the DB or the gate and per-day dedup break.
  dayEpoch Int?

  // Supply metrics. circulatingSupply is nullable: it is intentionally unset for
  // the 2023 upgrade window where staked (hence restricted/circulating) can't be
  // read; coercing it to 0 would surface a false "0 circulating".
  burnedSupply       Decimal  @db.Decimal(20, 6)
  mintedSupply       Decimal  @db.Decimal(20, 6)
  totalSupply        Decimal  @db.Decimal(20, 6)
  circulatingSupply  Decimal? @db.Decimal(20, 6)
  restrictedSupply   Decimal? @db.Decimal(20, 6)
  communitySupply    Decimal? @db.Decimal(20, 6)
  // Unvested developer-vesting module balance for this date. mintedSupply is on
  // the raw GetSupply basis, which includes this amount once (+); restrictedSupply
  // subtracts it once (-), netting to zero in circulating. Null on legacy rows.
  devVestingSupply   Decimal? @db.Decimal(20, 6)

  // Staking metrics
  inflationRate Decimal  @db.Decimal(10, 6)
  totalStaked   Decimal? @db.Decimal(20, 6)
  stakingApr    Decimal? @db.Decimal(10, 6)
  stakingRate   Decimal? @db.Decimal(10, 6)

  // Decentralization / validator metrics (daily). Backfilled from SmartStake CSV
  // history (Nakamoto/Gini from 2022-01, undelegations from 2025-07) and kept
  // current by the snapshot cron going forward. pendingUndelegations is the total
  // OSMO unbonding on that date (distinct from the live forward 14-day schedule).
  nakamotoCoefficient  Int?
  giniCoefficient      Decimal? @db.Decimal(10, 6)
  pendingUndelegations Decimal? @db.Decimal(20, 6)
  // Average seconds per block on this date. Backfilled from SmartStake history
  // (from 2022-10) and computed by the cron from daily block-height deltas.
  blockRate            Decimal? @db.Decimal(10, 4)
  // Latest block height at snapshot time; stored so the next day's cron can
  // derive blockRate from the height/time delta vs this row.
  blockHeight          BigInt?

  // Data-provenance markers. These make the one-off migration scripts idempotent
  // (normalize-supply-offset / backfill-genesis-2021 / recompute-inflation) and
  // flag the 2023 window where the restricted staked portion was reconstructed.
  // They MUST persist so re-running a migration over DB-exported JSON cannot
  // double-apply (e.g. subtracting the v27 supply offset twice).
  supplyOffsetNormalized Boolean?
  genesisBackfilled      Boolean?
  inflationRecomputed    Boolean?
  restrictedStakedPending Boolean?

  // Distribution parameters (stored as JSON for flexibility)
  distributionProportions            Json?
  osmoTakerFeeDistribution           Json?
  nonOsmoTakerFeeDistribution        Json?
  communityPoolDenomWhitelist        String[]
  communityPoolDenomToSwapNonWhitelistedAssetsTo String?

  // Revenue metrics (daily values in USD)
  txnFeesRevenue    Decimal? @db.Decimal(20, 2)
  takerFeesRevenue  Decimal? @db.Decimal(20, 2)
  protorevRevenue   Decimal? @db.Decimal(20, 2)
  mevRevenue        Decimal? @db.Decimal(20, 2)
  totalRevenue      Decimal? @db.Decimal(20, 2)

  // Metadata
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([timestamp(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("historical_records")
}

// Community-pool / DAO-treasury snapshot. Written hourly by the treasury cron and
// read whole by the /treasury page (the full decomposed breakdown lives in `data`
// as JSON; it is never queried by column). `totalValue` is duplicated out as a
// Decimal so a plausibility gate / headline can be read without parsing the blob.
model TreasurySnapshot {
  id        BigInt   @id @default(autoincrement())
  timestamp DateTime @unique @db.Timestamptz(6)

  // Headline USD value across all holders, mirrored from `data.totalValue` for
  // cheap querying. Decimal(20,2) — dollars, two places.
  totalValue Decimal @db.Decimal(20, 2)

  // Full TreasurySnapshotData payload (main pool + per-holder breakdown +
  // unpriced-symbol diagnostics). Shape owned by lib/treasury/snapshot.ts.
  data Json

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([timestamp(sort: Desc)])
  @@map("treasury_snapshots")
}

// Per-validator snapshot of metrics that can't be read live from the LCD:
// governance recency, slashing history, and long-run signing uptime. Sourced by
// importing SmartStake's Validators.csv (scripts/import-validator-snapshot.ts),
// keyed by operator address and joined into /api/validators. It's a point-in-time
// snapshot (updatedAt = "as of"), refreshed by re-importing — not live data.
model ValidatorSnapshot {
  operatorAddress String @id

  // Governance participation: votes in the last 10 proposals (SmartStake import).
  govVotesLast10 Int?

  // Slashing history.
  timesSlashed      Int?
  latestSlashedTime DateTime? @db.Timestamptz(6)

  // Long-run signing uptime % (SmartStake historicalPerSigned), a longer window
  // than the live ~80k-block slashing-window uptime shown elsewhere. NOTE: since
  // self-indexing, the leaderboard's long-run uptime is computed from ValidatorDaily
  // (trailing-90 average) when available; this stays as the SmartStake fallback for
  // validators with no accrued daily history yet.
  longRunUptime Decimal? @db.Decimal(7, 4)

  // Validator self-bond as a % of its own voting power (SmartStake selfBondPercentage).
  // Skin-in-the-game signal; imported, not live.
  selfBondPercentage Decimal? @db.Decimal(9, 4)

  // Slash tracking, maintained by the cron (distinct from the SmartStake import's
  // timesSlashed, which is the historical count as of the import). The cron
  // increments cronSlashCount when it detects a NEW jailing (jailed_until advances)
  // or a tombstone, and records the time. prevJailedUntil / prevTombstoned hold the
  // last-seen slashing state so the next run can detect a transition.
  cronSlashCount   Int?
  cronLastSlashTime DateTime? @db.Timestamptz(6)
  prevJailedUntil  DateTime? @db.Timestamptz(6)
  prevTombstoned   Boolean?

  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("validator_snapshots")
}

// Per-validator daily uptime reading (the ~80k-block slashing-window uptime, 0-1),
// written once a day by the snapshot cron for every bonded validator. The
// leaderboard's long-run uptime is the trailing-90-day average of these rows;
// keeping per-day rows (vs a rolling aggregate) also leaves a per-validator uptime
// history that can be charted later. ~135 rows/day; prune older-than-N-days
// eventually if it grows (only the trailing 90 are read).
model ValidatorDaily {
  operatorAddress String
  date            DateTime @db.Timestamptz(6) // UTC day
  uptime          Decimal  @db.Decimal(7, 6) // 0-1 slashing-window uptime that day

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@id([operatorAddress, date])
  @@index([operatorAddress, date(sort: Desc)])
  @@map("validator_daily")
}

// Per-completion-day unbonding amount: how much OSMO completes its unbonding on
// a given calendar day (UTC). This is a FLOW (amount completing that day),
// distinct from HistoricalRecord.pendingUndelegations, which is the outstanding
// POOL total (a stock). Kept in its own table because it's written a day AHEAD:
// the snapshot cron on day D reads the still-full "completes tomorrow" bucket and
// upserts the row for D+1 (reading it on D+1 itself would undercount, as entries
// complete through the day). A separate table also means the HistoricalRecord
// per-day delete-then-create can't clobber these forward-dated values.
// Backfilled from SmartStake's Undelegation History export (same per-day-completing
// definition) via scripts/import-undelegation-days.ts.
model UndelegationDay {
  // The UTC completion day (midnight), unique per day.
  date DateTime @id @db.Timestamptz(6)

  // OSMO completing unbonding on this day.
  amountCompleting Decimal @db.Decimal(20, 6)

  // "smartstake" (historical import) or "cron" (written going forward). Lets a
  // cron write supersede an imported value for the same day without ambiguity.
  source String

  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([date(sort: Asc)])
  @@map("undelegation_days")
}

// Latest unbonding FORECAST blob, computed once a day by the snapshot cron (which
// already enumerates every validator's unbonding_delegations — a ~71-call fan-out).
// Persisting it here means /api/undelegations reads one row instead of re-running
// that fan-out on every page load (which was rate-limited / 403'd by the public
// LCD). Single row, upserted each cron run (fixed id "latest"); we only ever need
// the current forecast (per-day-completing HISTORY lives in UndelegationDay).
model UnbondingForecast {
  // Fixed key so the cron upserts one row. Always "latest".
  id String @id

  // Full forecast payload: { total, days: [{date, amount}], topEntries:
  // [{delegator, validator, moniker, amount, completionTime}], fetchFailures }.
  // Shape owned by lib/validators.ts (UnbondingSchedule).
  data Json

  // When the cron computed this (for staleness display / debugging).
  computedAt DateTime @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  @@map("unbonding_forecast")
}
