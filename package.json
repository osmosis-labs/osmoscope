{
  "name": "osmometer",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard for displaying the main tokenomics of the OSMO token",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "test": "tsx --test lib/**/*.test.ts",
    "populate-from-archive": "tsx scripts/populate-from-archive.ts",
    "normalize-supply-offset": "tsx scripts/normalize-supply-offset.ts",
    "backfill-genesis-2021": "tsx scripts/backfill-genesis-2021.ts",
    "recompute-inflation": "tsx scripts/recompute-inflation.ts",
    "populate-staking-apr": "tsx scripts/populate-staking-apr-history.ts",
    "populate-revenue": "tsx scripts/populate-revenue-history.ts",
    "validate-history": "tsx scripts/validate-history.ts",
    "migrate-json-to-db": "tsx scripts/migrate-json-to-db.ts",
    "populate-treasury": "tsx scripts/populate-treasury.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.0.1",
    "@tanstack/react-query": "^5.59.0",
    "bech32": "^2.0.0",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "lru-cache": "^11.2.2",
    "modern-screenshot": "^4.7.0",
    "next": "^15.0.0",
    "pg": "^8.22.0",
    "prisma": "^7.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.8.7",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@4.5.1"
}
